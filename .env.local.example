# 本地开发设施与脚本配置模板。
# 逐项说明：
# VITE_DEV_PORT=Vite 本地开发端口
# VITE_ALLOWED_HOSTS=Vite 允许的 Host 白名单（逗号分隔）
# VITE_HMR_HOST=HMR 连接主机名
# VITE_HMR_PROTOCOL=HMR 协议（ws 或 wss）
# VITE_HMR_CLIENT_PORT=HMR 客户端端口
# VITE_DEV_BACKEND_PROXY_TARGET=本地开发时 /api 与 /auth 代理上游地址
# LOCAL_APP_DEV_DOMAIN=本地域名接管时浏览器访问域名（不含协议）
# LOCAL_APP_DEV_PROXY_REMOTE_ORIGIN=本地 HTTPS 代理转发的后端上游地址
# LOCAL_APP_DEV_PROXY_VITE_ORIGIN=本地 HTTPS 代理转发的 Vite 上游地址
# LOCAL_APP_DEV_PROXY_PORT=本地 HTTPS 代理监听端口
# LOCAL_APP_DEV_PROXY_CERT_PFX=本地 HTTPS 代理使用的 PFX 证书路径
# LOCAL_APP_DEV_PROXY_CERT_PASSPHRASE=本地 HTTPS 代理使用的 PFX 证书口令
# WORLD_SSH_HOST=SSH 目标主机别名
# WORLD_WORKSPACE_ROOT=world 前端项目本地绝对路径
# WORLD_REMOTE_ROOT=远端根目录基座（其余 WORLD_* 默认值由它拼接）
# WORLD_STATIC_STAGE_ROOT=远端发布暂存目录
# WORLD_STATIC_ROOT=远端静态站点根目录（原子发布目标）
# WORLD_PUBLISH_SCRIPT=远端发布脚本路径
# WORLD_SMOKE_BASE_URL=发布后烟雾测试访问基地址
# WORLD_FRONT_REFERENCE_ROOT=远端前端参考副本目录
# WORLD_FRONT_REFERENCE_TEMP_ROOT=远端前端参考副本上传临时目录
# WORLD_BACKEND_REFERENCE_ROOT=远端后端参考副本目录
# WORLD_BACKEND_REFERENCE_TEMP_ROOT=远端后端参考副本下载临时目录
# WORLD_BACKEND_REFERENCE_LOCAL_ROOT=本地后端参考副本目录
# VITE_DEBUG_APP=前端 App 调试开关
# VITE_DEBUG_WORKER=Worker 调试开关
# VITE_DEBUG_RUST=Rust/WASM 调试开关
# VITE_DEBUG_CHUNK=Chunk 调试开关
# VITE_DEBUG_TEXTURE=纹理调试开关
# VITE_DEBUG_RENDERER=渲染器调试开关
# VITE_DEBUG_RUNTIME=运行时调试开关

VITE_DEV_PORT=
VITE_ALLOWED_HOSTS=
VITE_HMR_HOST=
VITE_HMR_PROTOCOL=
VITE_HMR_CLIENT_PORT=
VITE_DEV_BACKEND_PROXY_TARGET=
LOCAL_APP_DEV_DOMAIN=
LOCAL_APP_DEV_PROXY_REMOTE_ORIGIN=
LOCAL_APP_DEV_PROXY_VITE_ORIGIN=
LOCAL_APP_DEV_PROXY_PORT=
LOCAL_APP_DEV_PROXY_CERT_PFX=
LOCAL_APP_DEV_PROXY_CERT_PASSPHRASE=
WORLD_SSH_HOST=
WORLD_WORKSPACE_ROOT=
WORLD_REMOTE_ROOT=
WORLD_STATIC_STAGE_ROOT=
WORLD_STATIC_ROOT=
WORLD_PUBLISH_SCRIPT=
WORLD_SMOKE_BASE_URL=
WORLD_FRONT_REFERENCE_ROOT=
WORLD_FRONT_REFERENCE_TEMP_ROOT=
WORLD_BACKEND_REFERENCE_ROOT=
WORLD_BACKEND_REFERENCE_TEMP_ROOT=
WORLD_BACKEND_REFERENCE_LOCAL_ROOT=
VITE_DEBUG_APP=
VITE_DEBUG_WORKER=
VITE_DEBUG_RUST=
VITE_DEBUG_CHUNK=
VITE_DEBUG_TEXTURE=
VITE_DEBUG_RENDERER=
VITE_DEBUG_RUNTIME=
