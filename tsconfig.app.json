{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "src/**/*.glsl"],
  "exclude": ["src/**/__tests__/*", "duplicated/duplictated/**/*", "scripts/**/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"],
      "@world-core": ["./core/pkg/world_core"],
      "@engine/*": ["./src/engine/*"],
      "@composables/*": ["./src/composables/*"],
      "@world/*": ["./src/world/*"],
      "@components/*": ["./src/components/*"],
      "@render/*": ["./src/engine/render/*"],
      "@shaders/*": ["./src/engine/render/shaders/*"]
    }
  }
}
