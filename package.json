{
  "name": "vuecraft",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "app-dev": "run-p host proxy:local-app",
    "app-dev:stop": "powershell -Command \"$ports = 443,5175,5176; Get-NetTCPConnection -State Listen -ErrorAction SilentlyContinue | Where-Object { $ports -contains $_.LocalPort } | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { $proc = Get-Process -Id $_ -ErrorAction SilentlyContinue; if ($proc -and $proc.ProcessName -eq 'node') { taskkill /PID $_ /F | Out-Null } }\"",
    "release:static": "run-s build:prod:static publish:static",
    "release:static:linux": "run-s build:prod:static publish:static:linux",
    "ref:front:push": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/push_front_reference.ps1",
    "ref:backend:pull": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/pull_backend_reference.ps1",
    "lint": "eslint . --fix",
    "type-check": "vue-tsc --build",
    "build:resource": "npx tsx ./scripts/BlockPaser/main.ts",
    "build:wasm": "run-s build:wasm:dev",
    "host": "vite --host",
    "preview": "vite preview",
    "proxy:local-app": "node ./scripts/dev/local_proxy/local_app_dev_proxy.mjs",
    "setup:local-app": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/local_proxy/setup_local_app_dev.ps1",
    "check:local-app": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/local_proxy/check_local_app_dev.ps1",
    "format": "prettier --write src/",
    "build": "run-s build:resource build:prod:static",

    "build-only": "vite build",
    "build:vite": "run-p type-check \"build-only {@}\" --",
    "build:wasm:prod": "npx wasm-pack build core --target web --release -- --no-default-features",
    "build:wasm:dev": "npx wasm-pack build core --target web --profiling -- --features dev-logging",
    "build:wasm:debug": "npx wasm-pack build core --target web --dev -- --features dev-logging",
    "build:prod:static": "run-s build:wasm:prod build:vite",
    "publish:static": "powershell -ExecutionPolicy Bypass -File ./scripts/dev/publish_static.ps1",
    "publish:static:linux": "bash ./scripts/dev/publish_static.sh"
  },
  "dependencies": {
    "gl-matrix": "^3.4.4",
    "pinia": "^3.0.3",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.19.2",
    "@types/pako": "^2.0.4",
    "@types/pngjs": "^6.0.4",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-basic-ssl": "^2.1.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.31.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "~10.3.0",
    "jiti": "^2.4.2",
    "npm-run-all2": "^8.0.4",
    "pako": "^2.1.0",
    "pngjs": "^7.0.0",
    "prettier": "3.6.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0",
    "vite": "^7.0.6",
    "vite-plugin-glsl": "^1.5.5",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vite-plugin-wasm": "^3.5.0",
    "vue-tsc": "^3.0.4",
    "wasm-pack": "^0.13.1",
    "xlsx": "^0.18.5"
  }
}
