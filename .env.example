# 前端运行时配置模板（用于 /config.js 与 window.APP_CONFIG）。
# 逐项说明：
# API_BASE_URL=后端 API 统一入口基地址
# AUTH_BASE_URL=认证服务入口基地址（OAuth/登录）
# APP_BASE_URL=前端应用主入口基地址
# SKIN_API_BASE_URL=皮肤服务 API 基地址
# MCA_BASE_URL=MCA 资源目录基路径
# MODEL_BASE_URL=模型资源根路径
# MODEL_COMPILED_BASE_URL=模型编译产物路径
# MODEL_ASSET_BASE_URL=模型静态资产路径
# BASIC_BASE_URL=基础资源根路径
# BASIC_COMPILED_BASE_URL=基础资源编译产物路径
# BASIC_ASSET_BASE_URL=基础资源静态资产路径
# SKIN_BASE_URL=皮肤静态资源路径（兜底目录）

API_BASE_URL=
AUTH_BASE_URL=
APP_BASE_URL=
SKIN_API_BASE_URL=
MCA_BASE_URL=
MODEL_BASE_URL=
MODEL_COMPILED_BASE_URL=
MODEL_ASSET_BASE_URL=
BASIC_BASE_URL=
BASIC_COMPILED_BASE_URL=
BASIC_ASSET_BASE_URL=
SKIN_BASE_URL=